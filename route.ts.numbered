    53	export async function POST(req: NextRequest) {
    54	  const APP_VERSION = 'v5.0-PDF_NATIVE';
    55	  console.time(`[${APP_VERSION}] webhook-total`);
    56	
    57	  let body: any = {};
    58	  let currentStage = 'init';
    59	  try {
    60	    currentStage = 'parsing_webhook';
    61	    try {
    62	      body = await req.json();
    63	    } catch (e) {
    64	      console.warn('Failed to parse webhook body');
    65	      return NextResponse.json({ status: 'invalid_json' });
    66	    }
    67	    console.log('[WEBHOOK] type:', body.typeWebhook, 'id:', body.idMessage);
    68	    const type = body.typeWebhook;
    69	
    70	    const isIncoming = type === 'incomingMessageReceived' || type === 'webhookIncomingMessageReceived';
    71	    const isOutgoing = type === 'outgoingMessageReceived' || type === 'outgoingAPIMessageReceived';
    72	
    73	    const idMessage = body.idMessage;
    74	    if (idMessage && (isIncoming || isOutgoing)) {
    75	      if (await isWebhookProcessed(idMessage)) {
    76	        console.log(`[DEDUPLICATION] Skipping already processed webhook: ${idMessage} (Type: ${type})`);
    77	        return NextResponse.json({ status: 'success_deduplicated_by_id' });
    78	      }
    79	    }
    80	
    81	    if (isIncoming || isOutgoing) {
    82	      const { senderData, messageData } = body;
    83	      
    84	      if ((!senderData && isIncoming) || !messageData) {
    85	        console.warn('Missing senderData or messageData in webhook body');
    86	        return NextResponse.json({ status: 'invalid_payload' });
    87	      }
    88	
    89	      const chatId = senderData?.chatId || body.chatId || messageData?.chatId;
    90	      const wid = body.instanceData?.wid;
    91	      const rawSender = isIncoming ? senderData?.sender : (senderData?.sender || body.senderData?.sender || chatId);
    92	      const rawSenderClean = (rawSender || '').replace(/\D/g, '');
    93	      const chatIdClean = chatId.replace(/\D/g, '');
    94	      const widNumber = (wid || '').split('@')[0].replace(/\D/g, '').trim();
    95	      
    96	      // Exact match on last 9 significant digits — avoids substring/forgery attacks via chatId
    97	      const SUPER_USER_SUFFIXES = new Set(['526672663']);
    98	      const senderSuffix = rawSenderClean.slice(-9);
    99	      const isSuperUser = senderSuffix.length === 9 && SUPER_USER_SUFFIXES.has(senderSuffix);
   100	
   101	      // Known contacts with special roles
   102	      const ACCOUNTANT_SUFFIXES = new Set(['543972690']); // אייל אסרף - רואה חשבון
   103	      const isAccountant = senderSuffix.length === 9 && ACCOUNTANT_SUFFIXES.has(senderSuffix);
   104	
   105	      if (chatId.endsWith('@g.us')) {
   106	        console.log(`Ignoring group message from ${chatId}`);
   107	        return NextResponse.json({ status: 'ignored_group' });
   108	      }
   109	
   110	      let contactName = '';
   111	      let visionError: string | null = null;
   112	      let fileData: any = null;
   113	      currentStage = 'initialization';
   114	      
   115	      try {
   116	        const contactInfo = await greenApi.getContactInfo(chatId);
   117	        contactName = contactInfo.contactName || '';
   118	      } catch (e) {
   119	        contactName = senderData?.senderName || '';
   120	      }
   121	
   122	      const pushName = senderData?.senderName || '';
   123	      // PRIORITY: contactName (from phone contacts) > pushName (WhatsApp profile name set by sender)
   124	      const senderName = contactName || pushName || '';
   125	
   126	      // Filters
   127	      const blacklist = ['אמא', 'Mom', 'אוריה חיים שלי', 'אריאלי', 'שלומי ידיד', 'קימי', 'קארין', 'סבינה גננת', 'ירון שרעבי', 'חברה שחלו', 'שחלו עובדת', 'זהבה', 'פיני', 'אדיר', 'רז', 'חיים בל'];
   128	      const blacklistedNumbers = ['972546349803', '0546349803', '546349803', '972542619636', '0542619636', '542619636', '998910366781', '972536553345', '536553345'];
   129	      
   130	      const isBlacklisted = (isIncoming && !isSuperUser && (
   131	        blacklist.some(name => (senderName && senderName.includes(name))) ||
   132	        blacklistedNumbers.some(num => (chatIdClean && chatIdClean.includes(num)))
   133	      ));
   134	
   135	      if (isBlacklisted) {
   136	        console.log(`[FILTER] Explicitly ignored blacklisted contact: ${senderName} (${chatId})`);
   137	        return NextResponse.json({ status: 'ignored_blacklisted' });
