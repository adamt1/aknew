   219	           }
   220	        }
   221	      } else if (isImage || isDocument || isVideo) {
   222	        const downloadUrl = messageData.fileMessageData?.downloadUrl || 
   223	                            messageData.imageMessageData?.downloadUrl || 
   224	                            messageData.documentMessageData?.downloadUrl ||
   225	                            messageData.videoMessageData?.downloadUrl;
   226	        
   227	        let mimeType = messageData.fileMessageData?.mimeType ||
   228	                         messageData.imageMessageData?.mimeType ||
   229	                         messageData.documentMessageData?.mimeType ||
   230	                         messageData.videoMessageData?.mimeType ||
   231	                         (isImage ? 'image/jpeg' : isVideo ? 'video/mp4' : 'application/pdf');
   232	
   233	        let originalPdfBuffer: Buffer | null = null;
   234	        try {
   235	          let fileBuffer: Buffer | null = null;
   236	          if (downloadUrl) {
   237	            assertTrustedDownloadUrl(downloadUrl);
   238	            console.log(`[MEDIA] Downloading ${typeMessage} via URL: ${downloadUrl}`);
   239	            fileBuffer = await greenApi.downloadFile(downloadUrl);
   240	          } else if (idMessage) {
   241	            console.log(`[MEDIA] Downloading ${typeMessage} via MessageId: ${idMessage}`);
   242	            fileBuffer = await greenApi.downloadFileByMessage(chatId, idMessage);
   243	          }
   244	
   245	          if (fileBuffer) {
   246	            console.log(`[MEDIA] Downloaded ${fileBuffer.length} bytes. Mime: ${mimeType}`);
   247	            
   248	            // HEIC/HEIF Support
   249	            if (mimeType.includes('heic') || mimeType.includes('heif')) {
   250	              try {
   251	                console.log('[VISION] Converting HEIC to JPG...');
   252	                fileBuffer = Buffer.from(await heicConvert({
   253	                  buffer: fileBuffer.buffer as ArrayBuffer,
