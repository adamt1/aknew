     9	
    10	function isRateLimitError(e: any): boolean {
    11	  const msg = (e?.message || '').toLowerCase();
    12	  const status = e?.status || e?.statusCode || e?.response?.status;
    13	  return status === 429 || msg.includes('too many requests') || msg.includes('rate limit') || msg.includes('ratelimit');
    14	}
    15	
    16	async function agentGenerateWithRetry(
    17	  agent: any,
    18	  messages: any[],
    19	  options: any,
    20	  maxRetries = 3
    21	): Promise<any> {
    22	  let lastError: any;
    23	  for (let attempt = 0; attempt <= maxRetries; attempt++) {
    24	    try {
    25	      return await agent.generate(messages, options);
    26	    } catch (e: any) {
    27	      lastError = e;
    28	      if (isRateLimitError(e) && attempt < maxRetries) {
    29	        const delay = Math.min(1000 * Math.pow(2, attempt), 8000); // 1s, 2s, 4s max 8s
    30	        console.warn(`[RATE_LIMIT] Attempt ${attempt + 1}/${maxRetries + 1} failed. Retrying in ${delay}ms...`);
    31	        await new Promise(res => setTimeout(res, delay));
    32	        continue;
    33	      }
    34	      throw e;
    35	    }
    36	  }
    37	  throw lastError;
    38	}
    39	
    40	function assertTrustedDownloadUrl(url: string): void {
    41	  let parsed: URL;
    42	  try {
    43	    parsed = new URL(url);
    44	  } catch {
    45	    throw new Error(`Invalid download URL: ${url}`);
    46	  }
    47	  const allowedSuffixes = ['.greenapi.com', '.green-api.com', '.digitaloceanspaces.com'];
    48	  if (!allowedSuffixes.some(suffix => parsed.hostname.endsWith(suffix))) {
    49	    throw new Error(`Untrusted download URL host: ${parsed.hostname}`);
    50	  }
    51	}
