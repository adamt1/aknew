   199	        return NextResponse.json({ status: `${mediaLabel}_acknowledged` });
   200	      }
   201	
   202	      if (isVoiceMessage) {
   203	        const downloadUrl = messageData.fileMessageData?.downloadUrl;
   204	        if (downloadUrl) {
   205	           try {
   206	             assertTrustedDownloadUrl(downloadUrl);
