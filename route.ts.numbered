   363	        console.log('[FILTER] No actionable text or media found. Skipping agent processing.');
   364	        return NextResponse.json({ status: 'no_actionable_content' });
   365	      }
   366	
   367	      await saveMessage(chatId, 'user', text || placeholder);
   368	      const history = await getHistory(chatId);
   369	
   370	      const messageDate = body.timestamp ? new Date(body.timestamp * 1000) : new Date();
   371	      const serverDate = new Date();
