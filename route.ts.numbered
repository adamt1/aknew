   261	                throw new Error('אירעה שגיאה בעיבוד תמונה מהאייפון (HEIC). אנא שלח צילום מסך רגיל.');
   262	              }
   263	            }
   264	            
   265	            // PDF Extraction (Hybrid Flow: Text first, then Image)
   266	            if (mimeType === 'application/pdf' && fileBuffer) {
