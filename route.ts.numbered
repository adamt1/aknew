   147	
   148	      const typeMessage = messageData.typeMessage;
   149	      const isVoiceMessage = typeMessage === 'audioMessage';
   150	
   151	      // NEW: Ignore non-content types like reactions, polls, etc.
   152	      const ignoredTypes = ['reactionMessage', 'pollMessage', 'pollUpdateMessage', 'editedMessage', 'deletedMessage', 'stickerMessage'];
   153	      if (isIncoming && ignoredTypes.includes(typeMessage)) {
   154	        console.log(`[FILTER] Ignoring non-content message type: ${typeMessage}`);
