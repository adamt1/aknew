   288	                  viewportScale: 1.5 // Lower scale for context
   289	                });
   290	                if (pngPages.length > 0 && pngPages[0].content) {
   291	                  fileBuffer = Buffer.from(pngPages[0].content);
   292	                  mimeType = 'image/png';
   293	                  console.log(`[VISION] PDF converted to image context.`);
   294	                }
   295	              } catch (pdfErr: any) {
   296	                console.warn(`[PDF Image Fallback Failed] ${pdfErr.message}`);
   297	                // If text exists, we don't care about image conversion failing
   298	              }
   299	            }
   300	
   301	            // Vision processing for images and documents
   302	            const SUPPORTED_VISION_MIMES = ['image/jpeg', 'image/png', 'image/webp'];
