   275	                  text = `${text || '[מסמך PDF]'}\n\n--- תוכן טקסטואלי שחולץ מהמסמך ---\n${extractedText}`;
   276	                  // Mark as processed text-wise, might still try image thumbnail for context
   277	                  console.log(`[VISION] PDF text extracted: ${extractedText.length} chars.`);
   278	                }
   279	              } catch (pdfParseErr: any) {
